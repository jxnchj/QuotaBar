{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuotaBar",
  "version": "0.1.0",
  "identifier": "com.hanson.quotabar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "popover",
        "title": "QuotaBar",
        "width": 320,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Utility",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "exceptionDomain": "claude.ai"
    }
  },
  "plugins": {}
}
