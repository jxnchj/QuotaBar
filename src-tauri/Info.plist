<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Menu-bar-only agent: no Dock icon, no app menu (operated entirely from the status bar). -->
	<key>LSUIElement</key>
	<true/>
	<!-- Keep the 5-minute background refresh timer firing on schedule: stop macOS
	     App Nap from throttling/suspending this idle menu-bar agent. -->
	<key>NSAppSleepDisabled</key>
	<true/>
</dict>
</plist>
